{
  "expo": {
    "name": "MobileVerifier",
    "slug": "mobile-verifier",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobile-verifier",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.mobileverifier"
    },
    "android": {
      "minSdkVersion": 24,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
        "buildProperties": {
          "kotlinVersion": "2.0.21"
         },
      "package": "com.anonymous.mobileverifier"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      [
         "expo-build-properties",
       {
         "android" : {
            "kotlinVersion": "2.0.21",
            "newArchEnabled": false
       }
    }
  ]
],
    "updates": {
      "enabled": false,
      "checkAutomatically": "NEVER",
      "fallbackToCacheTimeout": 0
    },
    "extra": {
      "eas": {
        "projectId": "dc7ef6ab-79ff-421a-9e3e-5fc6d4699379"
      }
    }
  }
}
