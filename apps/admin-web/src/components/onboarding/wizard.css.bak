/* Wizard CSS */
:root {
    --bg: #080E18;
    --bg-card: #0D1525;
    --bg-step-bar: #0A1120;
    --bg-input: #091019;
    --border: rgba(255, 255, 255, 0.06);
    --border-input: rgba(255, 255, 255, 0.08);

    /* Emerald primary */
    --em: #10B981;
    --em-light: #34D399;
    --em-glow: rgba(16, 185, 129, 0.18);
    --em-border: rgba(16, 185, 129, 0.35);

    /* Rose accent */
    --rose: #F43F5E;
    --rose-glow: rgba(244, 63, 94, 0.14);

    /* Amber tag */
    --amber: #FBBF24;
    --amber-glow: rgba(251, 191, 36, 0.12);

    --text: #E9EFF8;
    --text-sub: #637E9E;
    --text-muted: #2E435C;
}

*,
*::before,
*::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
}

body {
    background: var(--bg);
    font-family: 'DM Sans', sans-serif;
    color: var(--text);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    overflow-x: hidden;
}

/* dot-grid bg */
body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: radial-gradient(rgba(16, 185, 129, 0.09) 1px, transparent 1px);
    background-size: 26px 26px;
    pointer-events: none;
    z-index: 0;
}

/* top glow */
body::after {
    content: '';
    position: fixed;
    top: -25%;
    left: 50%;
    transform: translateX(-50%);
    width: 900px;
    height: 500px;
    background: radial-gradient(ellipse, rgba(16, 185, 129, 0.07) 0%, transparent 65%);
    pointer-events: none;
    z-index: 0;
}

/* ── NAV ── */
nav {
    position: relative;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 44px;
    height: 62px;
    border-bottom: 1px solid var(--border);
    background: rgba(8, 14, 24, 0.88);
    backdrop-filter: blur(18px);
}

.logo {
    display: flex;
    align-items: center;
    gap: 11px;
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: 17px;
    letter-spacing: -0.3px;
    color: var(--text);
}

.logo-mark {
    width: 32px;
    height: 32px;
    border-radius: 9px;
    background: linear-gradient(140deg, var(--em-light), var(--em));
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 0 20px var(--em-glow), 0 0 0 1px rgba(16, 185, 129, 0.25);
}

.logo-mark svg {
    width: 16px;
    height: 16px;
}

.nav-badge {
    font-family: 'DM Mono', monospace;
    font-size: 9.5px;
    font-weight: 500;
    color: var(--amber);
    background: var(--amber-glow);
    border: 1px solid rgba(251, 191, 36, 0.28);
    padding: 2px 8px;
    border-radius: 20px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
}

.logout-btn {
    font-family: 'DM Mono', monospace;
    font-size: 11.5px;
    color: var(--text-muted);
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px 12px;
    border-radius: 6px;
    letter-spacing: 0.04em;
    transition: color .2s, background .2s;
    display: flex;
    align-items: center;
    gap: 6px;
}

.logout-btn:hover {
    color: var(--text-sub);
    background: rgba(255, 255, 255, 0.04);
}

/* ── MAIN ── */
main {
    position: relative;
    z-index: 1;
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 44px 24px;
}

/* ── CARD ── */
.card {
    width: 100%;
    max-width: 660px;
    background: var(--bg-card);
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 22px;
    overflow: hidden;
    box-shadow:
        0 0 0 1px rgba(255, 255, 255, 0.025) inset,
        0 40px 80px rgba(0, 0, 0, 0.55),
        0 0 120px rgba(16, 185, 129, 0.05);
    animation: cardIn .55s cubic-bezier(.22, 1, .36, 1) both;
}

@keyframes cardIn {
    from {
        opacity: 0;
        transform: translateY(24px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }
}

/* ════════════════════════════════════════
   STEP PROGRESS BAR  — fully defined
════════════════════════════════════════ */
.steps-bar {
    display: grid;
    grid-template-columns: 1fr auto 1fr auto 1fr;
    align-items: center;
    background: var(--bg-step-bar);
    border-bottom: 1px solid var(--border);
    padding: 0;
}

/* connector line between steps */
.step-connector {
    height: 2px;
    background: rgba(255, 255, 255, 0.06);
    margin: 0 -1px;
    position: relative;
    top: -10px;
    /* nudge up to align with icon center */
}

.step {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    padding: 22px 16px 18px;
    position: relative;
    transition: background .3s;
    cursor: default;
}

/* active step background wash */
.step.active {
    background: linear-gradient(180deg, rgba(16, 185, 129, 0.07) 0%, rgba(16, 185, 129, 0.02) 100%);
}

/* active bottom bar */
.step.active::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 12px;
    right: 12px;
    height: 3px;
    border-radius: 3px 3px 0 0;
    background: linear-gradient(90deg, var(--em-light), var(--em));
    box-shadow: 0 0 10px var(--em-glow);
}

/* step circle icon */
.step-circle {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all .3s;
    flex-shrink: 0;
    position: relative;
    z-index: 1;
}

.step.inactive .step-circle {
    background: rgba(255, 255, 255, 0.04);
    border: 2px solid rgba(255, 255, 255, 0.08);
}

.step.active .step-circle {
    background: linear-gradient(140deg, var(--em-light), var(--em));
    border: 2px solid rgba(52, 211, 153, 0.35);
    box-shadow:
        0 0 0 6px rgba(16, 185, 129, 0.1),
        0 0 24px rgba(16, 185, 129, 0.35);
}

.step-circle svg {
    width: 19px;
    height: 19px;
    stroke-width: 1.9;
    stroke-linecap: round;
    stroke-linejoin: round;
    fill: none;
}

.step.inactive .step-circle svg {
    stroke: rgba(255, 255, 255, 0.2);
}

.step.active .step-circle svg {
    stroke: #fff;
}

/* step text */
.step-meta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3px;
    text-align: center;
}

.step-index {
    font-family: 'DM Mono', monospace;
    font-size: 9.5px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    line-height: 1;
}

.step.inactive .step-index {
    color: var(--text-muted);
}

.step.active .step-index {
    color: rgba(52, 211, 153, 0.75);
}

.step-name {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 13.5px;
    letter-spacing: -0.2px;
    line-height: 1;
}

.step.inactive .step-name {
    color: rgba(255, 255, 255, 0.18);
}

.step.active .step-name {
    color: var(--text);
}

/* ── CARD BODY ── */
.card-body {
    padding: 34px 40px 28px;
}

.eyebrow {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    font-weight: 500;
    color: var(--em-light);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    margin-bottom: 10px;
    display: flex;
    align-items: center;
    gap: 8px;
}

.eyebrow-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--em-light);
    box-shadow: 0 0 8px var(--em-glow);
    animation: pulse 2.2s ease-in-out infinite;
}

@keyframes pulse {

    0%,
    100% {
        opacity: 1;
        transform: scale(1);
    }

    50% {
        opacity: .45;
        transform: scale(.75);
    }
}

h1 {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 25px;
    letter-spacing: -0.5px;
    color: var(--text);
    margin-bottom: 8px;
    line-height: 1.25;
}

.sub {
    font-size: 13.5px;
    font-weight: 300;
    color: var(--text-sub);
    line-height: 1.65;
    margin-bottom: 30px;
}

/* ── FORM ── */
.form-group {
    margin-bottom: 18px;
}

label {
    display: block;
    font-family: 'DM Mono', monospace;
    font-size: 10.5px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.09em;
    color: var(--text-sub);
    margin-bottom: 7px;
}

input[type="text"],
input[type="url"] {
    width: 100%;
    background: var(--bg-input);
    border: 1px solid var(--border-input);
    border-radius: 10px;
    padding: 12px 16px;
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    font-weight: 400;
    outline: none;
    transition: border-color .2s, box-shadow .2s;
}

input::placeholder {
    color: var(--text-muted);
    font-size: 13px;
}

input:focus {
    border-color: var(--em-border);
    box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.09);
}

.row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
}

/* ── DROPZONE ── */
.dropzone {
    border: 1.5px dashed rgba(16, 185, 129, 0.25);
    border-radius: 12px;
    background: rgba(16, 185, 129, 0.03);
    padding: 34px 24px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    cursor: pointer;
    margin-top: 7px;
    transition: border-color .25s, background .25s;
}

.dropzone:hover {
    border-color: rgba(16, 185, 129, 0.5);
    background: rgba(16, 185, 129, 0.07);
}

.cloud-icon {
    width: 46px;
    height: 46px;
    background: rgba(16, 185, 129, 0.1);
    border: 1px solid rgba(16, 185, 129, 0.22);
    border-radius: 13px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--em-light);
}

.dropzone-title {
    font-size: 14px;
    font-weight: 500;
    color: var(--text);
}

.dropzone-sub {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    color: var(--text-muted);
    letter-spacing: .04em;
}

.dropzone-tags {
    display: flex;
    gap: 6px;
}

.tag {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    padding: 3px 9px;
    border-radius: 5px;
    background: rgba(16, 185, 129, 0.1);
    border: 1px solid rgba(16, 185, 129, 0.2);
    color: var(--em-light);
    text-transform: uppercase;
    letter-spacing: .06em;
}

/* ── FOOTER ── */
.card-footer {
    padding: 18px 40px 26px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-top: 1px solid var(--border);
}

.progress-hint {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    color: var(--text-muted);
    display: flex;
    align-items: center;
    gap: 10px;
}

.dots {
    display: flex;
    gap: 5px;
    align-items: center;
}

.dot {
    border-radius: 99px;
    transition: all .3s;
}

.dot.active {
    width: 20px;
    height: 5px;
    background: var(--em-light);
    box-shadow: 0 0 8px var(--em-glow);
}

.dot.inactive {
    width: 5px;
    height: 5px;
    background: rgba(255, 255, 255, 0.08);
}

.next-btn {
    display: flex;
    align-items: center;
    gap: 9px;
    background: linear-gradient(135deg, var(--em-light) 0%, var(--em) 100%);
    color: #051510;
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: 14px;
    letter-spacing: .01em;
    border: none;
    border-radius: 11px;
    padding: 13px 28px;
    cursor: pointer;
    transition: transform .15s, box-shadow .2s;
    box-shadow: 0 4px 24px rgba(16, 185, 129, 0.28), 0 0 0 1px rgba(52, 211, 153, 0.2);
    position: relative;
    overflow: hidden;
}

.next-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.14), transparent);
    opacity: 0;
    transition: opacity .2s;
}

.next-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(16, 185, 129, 0.42);
}

.next-btn:hover::before {
    opacity: 1;
}

.next-btn:active {
    transform: translateY(0);
}

.next-btn svg {
    width: 15px;
    height: 15px;
}

@media(max-width:540px) {
    nav {
        padding: 0 20px;
    }

    .card-body,
    .card-footer {
        padding-left: 22px;
        padding-right: 22px;
    }

    .row {
        grid-template-columns: 1fr;
    }

    h1 {
        font-size: 21px;
    }

    .step-name {
        font-size: 11.5px;
    }
}

/* =========================================
 STEP 2 SPECIFIC STYLES
========================================= */
.form-label {
    display: flex;
    align-items: center;
    gap: 7px;
    font-family: 'DM Mono', monospace;
    font-size: 10.5px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.09em;
    color: var(--text-sub);
    margin-bottom: 10px;
}

.form-label .hint {
    margin-left: auto;
    font-family: 'DM Mono', monospace;
    font-size: 9px;
    color: var(--text-muted);
    text-transform: none;
    letter-spacing: 0;
    font-weight: 400;
}

/* DEPT TAGS */
.tags-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 12px;
}

.dept-tag {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    background: rgba(16, 185, 129, 0.10);
    border: 1px solid rgba(16, 185, 129, 0.22);
    border-radius: 8px;
    padding: 6px 12px;
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    font-weight: 400;
    color: var(--em-light);
    cursor: default;
    transition: background .18s, border-color .18s, box-shadow .18s;
    animation: tagIn .22s cubic-bezier(.34, 1.56, .64, 1) both;
}

.dept-tag:hover {
    background: rgba(16, 185, 129, 0.16);
    border-color: rgba(16, 185, 129, 0.4);
    box-shadow: 0 0 12px rgba(16, 185, 129, 0.12);
}

@keyframes tagIn {
    from {
        opacity: 0;
        transform: scale(.88) translateY(4px);
    }

    to {
        opacity: 1;
        transform: scale(1) translateY(0);
    }
}

.tag-remove {
    background: none;
    border: none;
    cursor: pointer;
    padding: 0 0 0 2px;
    display: flex;
    align-items: center;
    color: rgba(52, 211, 153, 0.55);
    font-size: 15px;
    line-height: 1;
    transition: color .18s;
}

.dept-tag:hover .tag-remove {
    color: #fff;
}

/* DIVIDER */
.divider {
    height: 1px;
    background: var(--border);
    margin: 0 0 24px;
}

/* ROLES */
.roles-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
}

.role-row {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 13px 16px;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid var(--border-input);
    border-radius: 11px;
    cursor: pointer;
    transition: background .2s, border-color .2s, box-shadow .2s;
    animation: fadeUp .3s cubic-bezier(.22, 1, .36, 1) both;
}

.role-row:nth-child(1) {
    animation-delay: .05s;
}

.role-row:nth-child(2) {
    animation-delay: .10s;
}

.role-row:nth-child(3) {
    animation-delay: .15s;
}

@keyframes fadeUp {
    from {
        opacity: 0;
        transform: translateY(10px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.role-row.checked {
    background: rgba(16, 185, 129, 0.06);
    border-color: rgba(16, 185, 129, 0.28);
    box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.08);
}

.check-box {
    width: 20px;
    height: 20px;
    border-radius: 6px;
    flex-shrink: 0;
    background: var(--bg-input);
    border: 2px solid rgba(255, 255, 255, 0.12);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background .18s, border-color .18s, box-shadow .18s;
}

.role-row.checked .check-box {
    background: linear-gradient(135deg, var(--em-light), var(--em));
    border-color: var(--em);
    box-shadow: 0 0 10px rgba(16, 185, 129, 0.35);
}

.check-box svg {
    display: none;
}

.role-row.checked .check-box svg {
    display: block;
}

.role-label {
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    font-weight: 400;
    color: var(--text-sub);
    transition: color .18s;
    user-select: none;
    flex: 1;
}

.role-row.checked .role-label {
    color: var(--text);
    font-weight: 500;
}

.role-badge {
    font-family: 'DM Mono', monospace;
    font-size: 9.5px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.09em;
    color: var(--em-light);
    background: var(--em-tag);
    border: 1px solid rgba(16, 185, 129, 0.22);
    padding: 2px 8px;
    border-radius: 20px;
    opacity: 0;
    transition: opacity .2s;
}

.role-row.checked .role-badge {
    opacity: 1;
}

.helper-note {
    margin-top: 12px;
    font-family: 'DM Mono', monospace;
    font-size: 10.5px;
    color: var(--text-muted);
    letter-spacing: 0.02em;
    display: flex;
    align-items: center;
    gap: 6px;
}

.footer-left {
    display: flex;
    align-items: center;
    gap: 10px;
}

.back-btn {
    display: flex;
    align-items: center;
    gap: 7px;
    background: none;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 10px;
    padding: 11px 20px;
    color: var(--text-sub);
    font-family: 'DM Mono', monospace;
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 0.04em;
    cursor: pointer;
    transition: color .2s, border-color .2s, background .2s;
}

.back-btn:hover {
    color: var(--text);
    border-color: rgba(255, 255, 255, 0.18);
    background: rgba(255, 255, 255, 0.04);
}

.progress-dots {
    display: flex;
    align-items: center;
    gap: 5px;
    margin-left: 4px;
}

.pdot {
    border-radius: 99px;
    transition: all .3s;
}

.pdot.done {
    width: 5px;
    height: 5px;
    background: rgba(16, 185, 129, 0.35);
}

.pdot.active {
    width: 20px;
    height: 5px;
    background: linear-gradient(90deg, var(--em-light), var(--em));
    box-shadow: 0 0 8px var(--em-glow);
}

.pdot.inactive {
    width: 5px;
    height: 5px;
    background: rgba(255, 255, 255, 0.08);
}

.step-count {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    color: var(--text-muted);
    letter-spacing: .04em;
}